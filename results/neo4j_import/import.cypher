// Constraints (run once)
CREATE CONSTRAINT species_id IF NOT EXISTS FOR (s:Species) REQUIRE s.id IS UNIQUE;
CREATE CONSTRAINT substrate_id IF NOT EXISTS FOR (s:Substrate) REQUIRE s.id IS UNIQUE;

